{
  "name": "tanimemo",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "../app/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tanimemo",
      "database_id": "83bb69fb-97a3-4485-a7bf-cd0865709ea6",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [{ "binding": "ATT", "bucket_name": "tanimemo-att" }]
}
